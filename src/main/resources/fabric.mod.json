			"vitosos.sapphireweapons.SapphireStarArmaments"
		],
		"client": [
			"vitosos.sapphireweapons.SapphireStarArmamentsClient"
		]
	},
	"mixins": [
		"sapphire-star-armaments.mixins.json",
